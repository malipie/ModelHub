# ── ModelHub Environment Variables ───────────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# .env is git-ignored; NEVER commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── MLflow ───────────────────────────────────────────────────────────────────
# Local dev: use SQLite backend (default when running outside Docker)
MLFLOW_TRACKING_URI=sqlite:///mlruns.db
# Docker stack: MLflow server with PostgreSQL backend
# MLFLOW_TRACKING_URI=http://mlflow-server:5001

MLFLOW_EXPERIMENT_NAME=churn_prediction
# Backend store for the mlflow-server container (PostgreSQL)
MLFLOW_BACKEND_STORE_URI=postgresql://modelhub:modelhub@postgres:5432/modelhub
MLFLOW_ARTIFACT_ROOT=/mlruns
MLFLOW_PORT=5001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=modelhub
POSTGRES_PASSWORD=modelhub
POSTGRES_DB=modelhub
# Full DSN used by the serving containers (psycopg2)
POSTGRES_DSN=postgresql://modelhub:modelhub@postgres:5432/modelhub

# ── Serving ───────────────────────────────────────────────────────────────────
MODEL_NAME=ecommerce-churn-predictor
# champion_pct is overridden per container in docker-compose.yml
CHAMPION_PCT=80

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=80

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=modelhub

# ── Training ─────────────────────────────────────────────────────────────────
RANDOM_SEED=42
